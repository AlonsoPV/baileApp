# Supabase Configuration
# Copia este archivo a .env y reemplaza con tus credenciales reales

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Image Transformations (/storage/v1/render/image/): srcset WebP en Explore. Requiere plan con transformaciones.
VITE_SUPABASE_IMAGE_TRANSFORMS=true
